// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "project_panel": {
    "diagnostic_badges": true
  },
  "current_line_highlight": "none",
  "preferred_line_length": 100,
  "proxy": "",
  "wrap_guides": [100],
  "show_wrap_guides": true,
  "colorize_brackets": false,
  "vim": {
    "toggle_relative_line_numbers": false,
  },
  "unnecessary_code_fade": 0.6,
  "toolbar": {
    "breadcrumbs": true,
  },
  "relative_line_numbers": "enabled",
  "tabs": {
    "show_diagnostics": "off",
    "git_status": false,
  },

  "title_bar": {
    "show_branch_icon": false,
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "cursor_shape": "bar",
  },
  "ui_font_weight": 500.0,
  "buffer_font_weight": 850.0,
  "icon_theme": {
    "mode": "dark",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 300,
  },
  "vim_mode": true,
  "base_keymap": "JetBrains",
  "ui_font_size": 18.0,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Subliminal Zed Light",
    "dark": "Subliminal Zed Dark",
  },

  "semantic_tokens": "combined",
  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        "token_type": "macro",
        "token_modifiers": ["library", "defaultLibrary"],
        "style": ["macro"],
      },
      {
        "token_type": "macro",
        "style": ["macro"],
      },
      {
        "token_type": "variable",
        "token_modifiers": ["mutable"],
        "style": ["mutable"],
      },
      {
        "token_type": "function",
        "token_modifiers": ["static", "associated"],
        "style": ["function.static"],
      },
    ],
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },
}
